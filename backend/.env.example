# --- SYSTEM CONFIG ---
NODE_ENV=development
PORT=5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
COOKIE_SECRET=your_super_secret_cookie_key

# --- DATABASE ---
MONGO_URI=mongodb://localhost:27017/localserve_dev

# --- AUTH (JWT) ---
# Secrets must be at least 32 characters long
JWT_ACCESS_SECRET=dev_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=dev_refresh_secret_min_32_chars_long

# --- REDIS ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- RAZORPAY ---
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAYX_ACCOUNT_NUMBER=your_razorpayx_account

# --- MSG91 (SMS Gateway) ---
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=your_msg91_sender_id

# --- FIREBASE (Notifications) ---
# Paste the entire service account JSON here as a string
FIREBASE_SERVICE_ACCOUNT={"project_id":"...","private_key":"...","client_email":"..."}

# --- EMAIL (Nodemailer/SendGrid) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@localserve.com
